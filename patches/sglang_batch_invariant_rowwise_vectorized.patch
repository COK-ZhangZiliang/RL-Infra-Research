+@triton.jit
+def _log_softmax_row_kernel(
+    input_ptr,
+    output_ptr,
+    input_row_stride: tl.constexpr,
+    output_row_stride: tl.constexpr,
+    n_cols: tl.constexpr,
+    BLOCK_SIZE: tl.constexpr,
+):
+    row_idx = tl.program_id(0).to(tl.int64)
+    offsets = tl.arange(0, BLOCK_SIZE)
+    mask = offsets < n_cols
+    input_row = input_ptr + row_idx * input_row_stride
+    output_row = output_ptr + row_idx * output_row_stride
+
+    vals = tl.load(input_row + offsets, mask=mask, other=-float("inf")).to(tl.float32)
+    row_max = tl.max(vals, axis=0)
+    exp_vals = tl.exp(vals - row_max)
+    denom = tl.sum(tl.where(mask, exp_vals, 0.0), axis=0)
+    out = vals - row_max - tl.log(denom)
+    tl.store(output_row + offsets, out, mask=mask)
+
+
