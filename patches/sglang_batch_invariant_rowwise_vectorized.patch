+def _get_int_env(name: str, default: int) -> int:
+    raw_value = os.getenv(name)
+    if raw_value is None:
+        return default
+    try:
+        value = int(raw_value)
+    except ValueError:
+        print(f"Invalid {name}={raw_value!r}; using {default}.")
+        return default
+    if value <= 0:
+        print(f"Invalid {name}={raw_value!r}; using {default}.")
+        return default
+    return value
+
