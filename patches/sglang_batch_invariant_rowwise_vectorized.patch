+def _rms_norm_row_kernel(
+    input_ptr,
+    weight_ptr,
+    output_ptr,
+    input_row_stride: tl.constexpr,
+    output_row_stride: tl.constexpr,
+    n_cols: tl.constexpr,
+    eps,
+    BLOCK_SIZE: tl.constexpr,
+):
+    row_idx = tl.program_id(0).to(tl.int64)
+    offsets = tl.arange(0, BLOCK_SIZE)
+    mask = offsets < n_cols
+    input_row = input_ptr + row_idx * input_row_stride
+    output_row = output_ptr + row_idx * output_row_stride
+
+    vals = tl.load(input_row + offsets, mask=mask, other=0.0).to(tl.float32)
+    weight = tl.load(weight_ptr + offsets, mask=mask, other=1.0).to(tl.float32)
+    sum_sq = tl.sum(tl.where(mask, vals * vals, 0.0), axis=0)
+    inv_rms = tl.rsqrt(sum_sq / n_cols + eps)
+    out = vals * inv_rms * weight
+    tl.store(output_row + offsets, out, mask=mask)
