+def _next_power_of_2(x: int) -> int:
+    return 1 << (x - 1).bit_length()
+
+
+def _rowwise_num_warps(block_size: int) -> int:
+    if block_size >= 8192:
+        return 8
+    if block_size >= 2048:
+        return 4
+    return 1
+
